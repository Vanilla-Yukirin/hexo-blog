.footer .build-stamp-footer
  margin-top: .35rem
  color: var(--text-color-secondary)
  font-size: .78em
  opacity: .9
  display: block
  text-align: center
  letter-spacing: .02em

  i
    margin-right: .32em
    font-size: .9em
    vertical-align: middle

.about-metrics
  display: flex
  flex-wrap: wrap
  align-items: center
  justify-content: center
  gap: 12px
  width: 100%
  margin: 8px 0 16px
  text-align: center
  clear: both

.about-metric-cell
  width: 320px
  max-width: 100%
  display: flex
  justify-content: center
  align-items: center

.about-metrics a
  display: block
  border-bottom: none !important
  box-shadow: none !important

.about-metrics a:hover
  border-bottom: none !important
  box-shadow: none !important

.about-metric-item
  width: 100%
  max-width: 320px
  height: auto
  display: block
  margin: 0 auto
  border-radius: 6px
