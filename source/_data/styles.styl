.footer .build-stamp-footer
  margin-top: .35rem
  color: var(--text-color-secondary)
  font-size: .78em
  opacity: .9
  display: block
  text-align: center
  letter-spacing: .02em

  i
    margin-right: .32em
    font-size: .9em
    vertical-align: middle

.about-metrics
  display: flex
  gap: 12px
  align-items: flex-start
  justify-content: center
  flex-wrap: wrap
  margin: 8px 0 16px

.about-metrics > p
  display: flex
  gap: 12px
  align-items: flex-start
  justify-content: center
  flex-wrap: wrap
  margin: 0

.about-metrics a
  display: block

.about-metric-item
  width: 320px
  max-width: 100%
  height: auto
  display: block
  border-radius: 6px
